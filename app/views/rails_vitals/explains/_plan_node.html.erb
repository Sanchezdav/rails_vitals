<% meta = node.metadata %>
<% node_id = "node_#{SecureRandom.hex(4)}" %>

<div class="<%= depth > 0 ? 'plan-node' : '' %>">
  <%# Node box — clickable %>
  <div
    class="node-box"
    onclick="toggleExplanation('<%= node_id %>')"
    style="background:<%= meta[:color] %>18;
           border:1px solid <%= meta[:color] %>44;"
  >
    <div
      style="display:flex;align-items:center;
                justify-content:space-between;flex-wrap:wrap;gap:8px;"
    >
      <%# Left — type + relation %>
      <div style="display:flex;align-items:center;gap:10px;">
        <span
          style="
          background:<%= meta[:color] %>33;
          color:<%= meta[:color] %>;
          font-size:12px;font-weight:bold;
          font-family:monospace;
          padding:3px 10px;border-radius:4px;
        "
        >
          <%= meta[:label] %>
        </span>

        <% if node.relation %>
          <span style="color:#e2e8f0;font-family:monospace;font-size:12px;">
            <%= node.relation %>

            <% if node.alias_name && node.alias_name != node.relation %>
              <span style="color:#718096;">(<%= node.alias_name %>)</span>
            <% end %>
          </span>
        <% end %>

        <% if node.index_name %>
          <span style="color:#9f7aea;font-family:monospace;font-size:11px;">
            via <%= node.index_name %>
          </span>
        <% end %>
      </div>

      <%# Right — cost + timing + rows %>
      <div style="display:flex;gap:16px;font-size:11px;font-family:monospace;">
        <div style="text-align:right;">
          <div style="color:#a0aec0;">cost</div>

          <div style="color:<%= cost_color(node.total_cost) %>;">
            <%= node.total_cost %>
          </div>
        </div>

        <% if node.actual_total_ms %>
          <div style="text-align:right;">
            <div style="color:#a0aec0;">actual</div>

            <div style="color:<%= time_color(node.actual_total_ms) %>;">
              <%= node.actual_total_ms %>ms
            </div>
          </div>
        <% end %>

        <div style="text-align:right;">
          <% if node.children.empty? %>
            <%# Leaf node — show planner accuracy %>
            <div style="color:#a0aec0;">est → actual</div>
            <div style="font-family:monospace;">
              <span style="color:#718096;"><%= node.plan_rows %></span>
              <span style="color:#4a5568;"> → </span>

              <% accuracy_color = node.plan_rows.to_i > 0 &&
                  (node.actual_rows.to_f / node.plan_rows.to_f) > 10 ? "#fc8181" : "#68d391" %>

              <span style="color:<%= accuracy_color %>;"><%= node.actual_rows %></span>
            </div>
          <% else %>
            <%# Intermediate node — show loops %>
            <div style="color:#a0aec0;">loops</div>
            <div
              style="color:<%= node.loops.to_i > 10 ? '#fc8181' : '#e2e8f0' %>;
                        font-family:monospace;"
            >
              <%= node.loops || 1 %>
            </div>
          <% end %>
        </div>

        <div style="text-align:right;">
          <div style="color:#a0aec0;">width</div>

          <div
            style="color:<%= node.plan_width.to_i > 200 ? '#f6ad55' : '#718096' %>;
                      font-family:monospace;"
          >
            <%= node.plan_width %>B
          </div>
        </div>
      </div>
    </div>

    <%# Index condition or filter %>
    <% if node.index_condition || node.filter %>
      <div
        style="margin-top:6px;font-family:monospace;font-size:10px;color:#718096;"
      >
        <% if node.index_condition %>
          <span style="color:#9f7aea;">Index Cond:</span>
          <%= node.index_condition %>
        <% end %>

        <% if node.filter %>
          <span style="color:#f6ad55;margin-left:8px;">Filter:</span>
          <%= node.filter %>
        <% end %>
      </div>
    <% end %>
  </div>

  <%# Stale statistics warning, only on leaf nodes with bad estimates %>
  <% if node.children.empty? && node.relation &&
        node.plan_rows.to_i > 0 &&
        (node.actual_rows.to_f / node.plan_rows.to_f) > 10 %>
    <div
      style="color:#f6ad55;font-size:11px;margin-top:4px;
                padding:6px 12px;background:#2d2010;border-radius:4px;"
    >
      ⚠ Planner estimated <%= node.plan_rows %> rows, got
      <%= node.actual_rows %>. Run
      <span style="font-family:monospace;">ANALYZE <%= node.relation %></span> to
      refresh table statistics.
    </div>
  <% end %>

  <%# Education card — hidden by default %>
  <% if meta[:explanation] %>
    <div
      id="<%= node_id %>"
      style="display:none;background:#2d3748;border-left:3px solid <%= meta[:color] %>;
                border-radius:4px;padding:12px 16px;margin-bottom:8px;
                margin-top:-4px;font-size:13px;color:#e2e8f0;line-height:1.6;"
    >
      <div
        style="color:<%= meta[:color] %>;font-weight:bold;
                  font-size:11px;text-transform:uppercase;
                  letter-spacing:0.05em;margin-bottom:6px;"
      >
        💡 <%= meta[:label] %>
      </div>

      <%= meta[:explanation] %>
    </div>
  <% end %>

  <%# Recurse into children %>
  <% node.children.each do |child| %>
    <%= render partial: "rails_vitals/explains/plan_node",
               locals: { node: child, depth: depth + 1 } %>
  <% end %>
</div>
