<div class="page-header">
  <h1 class="page-heading">Endpoint Heatmap</h1>
  <p class="page-subtitle">
    <%= @total %> requests recorded across <%= @heatmap.size %> endpoints
  </p>
</div>

<% if @heatmap.any? %>
  <div class="card">
    <table>
      <thead>
        <tr>
          <th>Endpoint</th>
          <th>Avg Score</th>
          <th>Hits</th>
          <th>Avg Queries</th>
          <th>Avg DB Time</th>
          <th>Avg Callback Time</th>
          <th>N+1 Frequency</th>
        </tr>
      </thead>
      <tbody>
        <% @heatmap.each do |row| %>
          <% color = score_label_to_color(row[:avg_score]) %>
          <tr>
            <td class="bold">
              <%= link_to row[:endpoint],
                    requests_path(endpoint: row[:endpoint]),
                    class: "text-accent" %>
            </td>
            <td>
              <span class="<%= badge_class(color) %>">
                <%= row[:avg_score] %>
              </span>
            </td>
            <td class="text-muted"><%= row[:hits] %></td>
            <td>
              <span style="color:<%= query_heat_color(row[:avg_queries]) %>">
                <%= row[:avg_queries] %>
              </span>
            </td>
            <td>
              <span style="color:<%= time_heat_color(row[:avg_db_time]) %>">
                <%= row[:avg_db_time] %>ms
              </span>
            </td>
            <td>
              <span style="color:<%= time_heat_color(row[:avg_callback_time]) %>">
                <%= row[:avg_callback_time] %>ms
              </span>
            </td>
            <td>
              <span style="color:<%= n1_heat_color(row[:n_plus_one_freq]) %>">
                <%= row[:n_plus_one_freq] %>%
              </span>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <%= render "rails_vitals/shared/empty_state",
             message: "No requests recorded yet. Visit your app to generate data." %>
<% end %>
