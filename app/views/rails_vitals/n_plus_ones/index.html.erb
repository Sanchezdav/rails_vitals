<div class="page-header">
  <h1 class="page-heading">N+1 Patterns</h1>
  <p class="page-subtitle">
    Aggregated across <%= @total_requests %> recorded requests
  </p>
</div>

<% if @patterns.any? %>
  <div class="card">
    <table>
      <thead>
        <tr>
          <th>Pattern</th>
          <th>Occurrences</th>
          <th>Affected Endpoints</th>
          <th>Fix</th>
          <th></th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @patterns.each do |p| %>
          <tr>
            <td class="mono text-sm text-muted truncate" style="max-width:300px;">
              <%= p[:pattern] %>
            </td>
            <td>
              <span class="text-danger bold"><%= p[:occurrences] %>x</span>
            </td>
            <td class="text-muted">
              <%= p[:endpoints].keys.join(", ") %>
            </td>
            <td class="mono text-sm text-healthy">
              <%= p[:fix_suggestion][:code] %>
            </td>
            <td>
              <%= link_to "Simulate →",
                    n_plus_one_path(pattern_id(p)),
                    class: "text-accent" %>
            </td>
            <td>
              <%= link_to "Try in Playground →",
                    rails_vitals.playgrounds_path(
                      expression: p[:fix_suggestion]&.dig(:code)
                    ),
                    class: "text-accent" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <div class="card empty-state">
    No N+1 patterns detected yet.
  </div>
<% end %>
